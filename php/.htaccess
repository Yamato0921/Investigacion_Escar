# Proteger archivos sensibles
<IfModule mod_rewrite.c>
    RewriteEngine On
    Options -Indexes
</IfModule>

<FilesMatch "\.(env|log|sqlite|db)$">
    Require all denied
</FilesMatch>

# Permitir acceso directo a imágenes en la carpeta de uploads
<IfModule mod_authz_core.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
        Require all granted
    </FilesMatch>
</IfModule>
